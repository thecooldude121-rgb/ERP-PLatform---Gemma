import { Type } from "@google/genai";

export interface EntityDefinition {
  title: string;
  description: string;
  type: "object";
  properties: {
    [propertyName: string]: {
      type: string;
      format?: string;
      description?: string;
      enum?: any[];
      $ref?: string;
    };
  };
  required?: string[];
}

export interface FirebaseBlueprintConfig {
  entities: {
    [entityName: string]: EntityDefinition;
  };
  firestore?: {
    [collectionPath: string]: {
      schema: string | { $ref: string };
      description: string;
    };
  };
}

